#!/bin/sh
### BEGIN INIT INFO
# Provides:          pydhcpd
# Required-Start:    $network $remote_fs
# Required-Stop:     $network $remote_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Python DHCP Daemon
# Description:       Starts, stops, restarts and reports status of pydhcpd
### END INIT INFO

# Author: maravento.com

set -e

DEFAULTS_FILE="/etc/pydhcp/default/pydhcpd"
DAEMON=/usr/bin/python3
DAEMON_ARGS=/etc/pydhcp/pydhcpd.py
NAME=pydhcpd
LOG_FILE="/var/log/pydhcpd.log"

# Read PID path from defaults file
PID_FILE="/etc/pydhcp/pydhcpd.pid"
if [ -f "$DEFAULTS_FILE" ]; then
    val=$(grep '^DHCPDv4_PID=' "$DEFAULTS_FILE" | cut -d= -f2 | xargs)
    [ -n "$val" ] && PID_FILE="$val"
fi

case "${1:-}" in
    start)
        echo "Starting $NAME..."
        if [ -f "$PID_FILE" ]; then
            pid=""
            read -r pid < "$PID_FILE" 2>/dev/null || true
            if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                echo "$NAME is already running (pid $pid)"
                exit 0
            fi
            rm -f "$PID_FILE"
        fi
        $DAEMON $DAEMON_ARGS &
        for _ in $(seq 1 40); do
            [ -f "$PID_FILE" ] && break
            sleep 0.25
        done
        pid=""
        [ -f "$PID_FILE" ] && { read -r pid < "$PID_FILE" 2>/dev/null || true; }
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            echo "$NAME started (pid $pid)"
        else
            echo "ERROR: $NAME failed to start. Check: $LOG_FILE"
            exit 1
        fi
        ;;
    stop)
        echo "Stopping $NAME..."
        if [ -f "$PID_FILE" ]; then
            pid=""
            read -r pid < "$PID_FILE" 2>/dev/null || true
            if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                kill "$pid" 2>/dev/null || true
                # Wait up to 5 seconds for process to terminate
                for _ in $(seq 1 20); do
                    kill -0 "$pid" 2>/dev/null || break
                    sleep 0.25
                done
                if kill -0 "$pid" 2>/dev/null; then
                    echo "WARNING: Process $pid did not terminate, forcing..."
                    kill -9 "$pid" 2>/dev/null || true
                fi
                echo "$NAME stopped"
            else
                echo "$NAME was not running (stale PID file)"
            fi
            rm -f "$PID_FILE"
        else
            echo "$NAME was not running"
        fi
        ;;
    restart)
        $0 stop
        sleep 1
        $0 start
        ;;
    status)
        if [ -f "$PID_FILE" ]; then
            pid=""
            read -r pid < "$PID_FILE" 2>/dev/null || true
            if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                echo "$NAME is running (pid $pid)"
                exit 0
            fi
        fi
        echo "$NAME is not running"
        exit 1
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
